# ============================
# App
# ============================
PORT=3000
NODE_ENV=development

# Segredo usado para assinar os JWT de login do painel administrativo. NÃO
# existe valor padrão no código — o servidor recusa subir sem isso definido
# (ver src/utils/jwt.js). Gere um valor novo com: openssl rand -hex 64
JWT_SECRET=

# Origens (domínios) autorizadas a fazer requisições cross-origin à API,
# separadas por vírgula (ex: https://seu-dominio.com,https://seu-app.northflank.app).
# Deixe em branco se o painel/portal são sempre servidos por este mesmo
# servidor (caso mais comum aqui) — nesse caso CORS nem entra em jogo, porque
# a requisição é same-origin.
CORS_ORIGIN=

# ============================
# Banco de dados
# ============================
# Local (SQLite em arquivo, sem Turso) - use isto para rodar 100% local sem conta na nuvem
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Turso (produção / Render) - gerado com `turso db create` e `turso db tokens create`
# DATABASE_URL=libsql://<seu-banco>-<sua-org>.turso.io
# DATABASE_AUTH_TOKEN=<token-gerado-pelo-turso-cli>

# ============================
# Mercado Pago (único provedor de pagamento suportado — a integração com a
# InfinitePay foi removida em 2026-07-07 por não estar em uso)
# ============================
MERCADOPAGO_ACCESS_TOKEN=

# Segredo usado para validar a assinatura ("x-signature") das notificações de
# webhook do Mercado Pago, evitando que qualquer requisição externa force uma
# atualização de status. Painel do Mercado Pago -> Sua aplicação -> Webhooks
# -> "Assinatura secreta". Sem isso configurado, o webhook continua
# funcionando (a checagem é pulada com um aviso no log), mas fica menos
# protegido — configure assim que tiver acesso ao painel.
MERCADOPAGO_WEBHOOK_SECRET=

# ============================
# Catraca Henry (integração direta via TCP/IP, porta padrão 3000)
# ============================
HENRY_CATRACA_IP=
HENRY_CATRACA_PORT=3000

# Token secreto que o "agente local" (pasta agente-local/, roda num PC da
# academia) usa para se autenticar no WebSocket deste servidor. Necessário
# só quando o painel está hospedado na nuvem (Northflank/Render) — é o que
# permite acionar a catraca mesmo sem o servidor estar na rede local dela.
# Gere uma string longa aleatória e use o MESMO valor no .env do agente.
AGENTE_TOKEN=

# ============================
# Totem/terminal de auto atendimento
# ============================
# Segredo compartilhado que o totem FÍSICO envia no header "X-Terminal-Token"
# em vez de login JWT (o aluno não tem usuário/senha). Fica embutido em
# public/terminal.js — por isso o dispositivo precisa ficar fisicamente
# controlado. Gere uma string longa aleatória.
TERMINAL_TOKEN=troque-por-uma-string-aleatoria-longa

# Segredo separado, mais restrito, usado pela página pública de auto-cadastro
# pelo celular (public/cadastro-mobile.js), aberta via QR "Usar seu cel" no
# totem. Diferente do TERMINAL_TOKEN, este é distribuído a QUALQUER visitante
# que escaneie o QR (não fica só no dispositivo físico controlado), então
# autoriza só as rotas de auto-cadastro — nunca abre a catraca sozinho nem
# libera acesso por CPF/rosto. Gere uma string longa aleatória, diferente do
# TERMINAL_TOKEN.
CADASTRO_PUBLICO_TOKEN=troque-por-outra-string-aleatoria-longa

# Distância máxima aceita entre o descritor facial capturado no totem e o
# descritor cadastrado do aluno para considerar "é a mesma pessoa" (face-api.js,
# menor = mais rígido). 0.6 é o padrão da biblioteca; 0.65 dá mais tolerância
# a variação de luz/ângulo do dia a dia, com um pouco menos de rigor.
FACE_MATCH_THRESHOLD=0.65
