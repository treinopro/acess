# ============================
# App
# ============================
PORT=3000
NODE_ENV=development
JWT_SECRET=troque-este-segredo-em-producao

# ============================
# Banco de dados
# ============================
# Local (SQLite em arquivo, sem Turso) - use isto para rodar 100% local sem conta na nuvem
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Turso (produção / Render) - gerado com `turso db create` e `turso db tokens create`
# DATABASE_URL=libsql://<seu-banco>-<sua-org>.turso.io
# DATABASE_AUTH_TOKEN=<token-gerado-pelo-turso-cli>

# ============================
# Mercado Pago
# ============================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ============================
# InfinitePay (InfinityPay)
# ============================
INFINITEPAY_HANDLE=seu-handle-sem-o-simbolo-$
INFINITEPAY_WEBHOOK_URL=https://seu-dominio.com/api/pagamentos/webhook/infinitepay

# Provedor de pagamento ativo por padrão: "mercadopago" ou "infinitepay"
PAYMENT_PROVIDER=mercadopago

# ============================
# Catraca Henry (integração direta via TCP/IP, porta padrão 3000)
# ============================
HENRY_CATRACA_IP=
HENRY_CATRACA_PORT=3000

# ============================
# Totem/terminal de auto atendimento
# ============================
# Segredo compartilhado que o totem envia no header "X-Terminal-Token" em vez
# de login JWT (o aluno não tem usuário/senha). Gere uma string longa aleatória.
TERMINAL_TOKEN=troque-por-uma-string-aleatoria-longa

# Distância máxima aceita entre o descritor facial capturado no totem e o
# descritor cadastrado do aluno para considerar "é a mesma pessoa" (face-api.js,
# menor = mais rígido). 0.6 é o padrão da biblioteca; 0.65 dá mais tolerância
# a variação de luz/ângulo do dia a dia, com um pouco menos de rigor.
FACE_MATCH_THRESHOLD=0.65
